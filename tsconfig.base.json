{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@adia/core": ["packages/core/src/index.ts"],
      "@adia/analyzers": ["packages/analyzers/src/index.ts"],
      "@adia/ingestion": ["packages/ingestion/src/index.ts"]
    }
  }
}
